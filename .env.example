DATABASE_URL=postgresql://memex:memex@localhost:5432/memex

# Optional tuning (defaults shown)
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=20
DEFAULT_ALPHA=0.7
RECENCY_DECAY_DAYS=30

# Concurrency
WORKERS=4                        # uvicorn worker processes
WORKER_THREAD_POOL_SIZE=16       # asyncio.to_thread() pool per worker

# Summarisation background job (fully local, no API needed)
SUMMARIZATION_ENABLED=true
SUMMARIZATION_THRESHOLD=100
SUMMARIZATION_BATCH_SIZE=50
SUMMARIZATION_INTERVAL_SECONDS=300
